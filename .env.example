# Shared
KLOUDBOY_ENV=development

# Backend
KLOUDBOY_HTTP_HOST=0.0.0.0
KLOUDBOY_HTTP_PORT=8443
KLOUDBOY_DATA_DIR=./data
KLOUDBOY_SITES_ROOT=./data/sites
KLOUDBOY_BACKUPS_ROOT=./data/backups
KLOUDBOY_LOGS_ROOT=./data/logs
KLOUDBOY_GENERATED_ROOT=./data/generated
KLOUDBOY_DB_PATH=./data/kloudboy.db
KLOUDBOY_STATIC_DIR=
